    "_postman_id": "93ed5bab-8363-4742-b86d-8c75fe3dabdc",
    "name": "Book Manager API",
    "description": "This collection contains the main endpoints for interacting with the Book Manager API. It covers user authentication and the complete book management workflow, including creating users, logging in, adding new books, listing all books, retrieving a book by ID, searching books by title with pagination, updating existing books, and deleting books.\n\nIt is intended to support development, testing, and validation of the API’s core features in a local environment.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "27016607"
  },
